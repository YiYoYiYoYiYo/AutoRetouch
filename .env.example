# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1/chat/completions
# OLLAMA_BASE_URL=http://localhost:11434/api/chat

# === 默认后端 (glm / agnes / ollama) ===
# DEFAULT_BACKEND=glm

# === 服务器绑定 ===
# SERVER_HOST=127.0.0.1
# SERVER_PORT=7860
